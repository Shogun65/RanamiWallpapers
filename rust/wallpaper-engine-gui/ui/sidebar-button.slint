export component SidebarButton inherits Rectangle {
    // Reusable sidebar button so every menu item keeps the same size and hover behavior.
    height: 42px;
    background: #261834;
    border-radius: 8px;
    border-width: 1px;
    border-color: #503172;

    in property <string> title;
    callback clicked();

    Text {
        x : 10px;
        text: title;
        color: white;
        font-size: 15px;
        vertical-alignment: center;
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    // Hover feedback helps placeholder buttons still feel interactive and consistent.
    states [
        hover when ta.has-hover: {
            background: #6030b8;
            border-color: #9f6dff;
        }
    ]
}
