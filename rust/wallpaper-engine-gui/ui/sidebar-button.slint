export component SidebarButton inherits Rectangle {
    // Reusable sidebar button so every menu item keeps the same size and hover behavior.
    height: 42px;
    background: #940cbe;
    border-radius: 8px;

    in property <string> title;
    callback clicked();

    Text {
        x : 10px;
        text: title;
        color: white;
        font-size: 15px;
        vertical-alignment: center;
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    // Hover feedback helps placeholder buttons still feel interactive and consistent.
    states [
        hover when ta.has-hover: {
            background: #30384a;
        }
    ]
}
