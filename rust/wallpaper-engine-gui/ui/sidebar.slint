import { VerticalBox } from "std-widgets.slint";
import { SidebarButton } from "sidebar-button.slint";

export component Sidebar inherits Rectangle {
    background: #120f1a;
    width: 220px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #2a2040;

    callback import_wallpaper();

    VerticalBox {
        padding: 10px;
        spacing: 10px;

        SidebarButton {
            title: "➕ Import Wallpaper";

            clicked => {
                root.import_wallpaper();
            }
        }

        // Simple separator between the one live action and the future sections below it.
        Rectangle {
            height: 1px;
            border-radius: 8px;
            background: #312648;
        }

        // These buttons are visual placeholders for features that can be wired later.
        SidebarButton {
            title : "⭐ Favorites";
        }

        SidebarButton {
            title : "⚙ Settings";
        }

        SidebarButton {
            title : "❕About";
        }
    }
}
