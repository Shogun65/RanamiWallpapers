export struct WallpaperCardData {
    title: string,
    path: string,
    format: string,
    thumbnail: image,
    has_thumbnail: bool,
}

export component WallpaperCard inherits Rectangle {
    // Each card receives everything it needs from Rust in one small data object.
    in property <WallpaperCardData> data;
    callback wallpaper_card_double_clicked(string);

    min-width: 220px;
    preferred-width: 240px;
    max-width: 280px;
    height: 238px;

    clip: true;
    background: #15111d;
    border-radius: 14px;
    border-width: 1px;
    border-color: #312548;

    Rectangle {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        height: 132px;
        background: #1b1329;
        border-radius: 10px;
        clip: true;

        // Show the cached ffmpeg preview when we have one.
        if data.has_thumbnail: Image {
            width: parent.width;
            height: parent.height;
            source: data.thumbnail;
            image-fit: cover;
        }

        // If preview generation failed, keep a clean fallback instead of breaking the card.
        if !data.has_thumbnail: Rectangle {
            background: #1b1329;

            Text {
                width: parent.width;
                y: parent.height / 2 - 11px;
                height: 22px;
                text: "Preview unavailable";
                color: #c7b6ff;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
            }
        }

        Rectangle {
            x: 12px;
            y: 12px;
            width: 72px;
            height: 24px;
            background: #9f3dff;
            border-radius: 12px;

            // Small format pill so the card still tells you what kind of file it points to.
            Text {
                text: data.format;
                color: white;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    Text {
        x: 12px;
        y: 154px;
        width: parent.width - 24px;
        height: 24px;
        text: data.title;
        color: white;
        font-size: 16px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: 12px;
        y: 184px;
        width: parent.width - 24px;
        height: 18px;
        text: data.path;
        color: #b4a8cb;
        font-size: 12px;
        overflow: elide;
    }

    Text {
        x: 12px;
        y: 208px;
        width: parent.width - 24px;
        height: 14px;
        text: data.has_thumbnail ? "Static thumbnail cached locally" : "Waiting for thumbnail preview";
        color: #7d7296;
        font-size: 11px;
        overflow: elide;
    }

    // Let the whole card surface act like one button instead of requiring precise clicks.
    // Send the wallpaper path only on double click, so single clicks stay harmless.
    touch-area := TouchArea {
        double-clicked => {
            root.wallpaper_card_double_clicked(data.path);
        }
    }
}
