export struct WallpaperCardData {
    title: string,
    path: string,
    format: string,
    thumbnail: image,
    has_thumbnail: bool,
}

export component WallpaperCard inherits Rectangle {

    in property <WallpaperCardData> data;

    min-width: 220px;
    preferred-width: 240px;
    max-width: 280px;
    height: 238px;

    clip: true;
    background: #161b24;
    border-radius: 14px;
    border-width: 1px;
    border-color: #2a3140;

    Rectangle {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        height: 132px;
        background: #112a37;
        border-radius: 10px;
        clip: true;

        // Show the cached ffmpeg preview when we have one.
        if data.has_thumbnail: Image {
            width: parent.width;
            height: parent.height;
            source: data.thumbnail;
            image-fit: cover;
        }

        // If preview generation failed, keep a clean fallback instead of breaking the card.
        if !data.has_thumbnail: Rectangle {
            background: #112a37;

            Text {
                width: parent.width;
                y: parent.height / 2 - 11px;
                height: 22px;
                text: "Preview unavailable";
                color: #80d0f5;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
            }
        }

        Rectangle {
            y: parent.height - 42px;
            width: parent.width;
            height: 42px;
            background: #00000055;
        }

        Rectangle {
            x: 12px;
            y: 12px;
            width: 72px;
            height: 24px;
            background: #9612c7;
            border-radius: 12px;

            Text {
                text: data.format;
                color: white;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    Text {
        x: 12px;
        y: 154px;
        width: parent.width - 24px;
        height: 24px;
        text: data.title;
        color: white;
        font-size: 16px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: 12px;
        y: 184px;
        width: parent.width - 24px;
        height: 18px;
        text: data.path;
        color: #9aa6bf;
        font-size: 12px;
        overflow: elide;
    }

    Text {
        x: 12px;
        y: 208px;
        width: parent.width - 24px;
        height: 14px;
        text: data.has_thumbnail ? "Static thumbnail cached locally" : "Waiting for thumbnail preview";
        color: #677188;
        font-size: 11px;
        overflow: elide;
    }
}
