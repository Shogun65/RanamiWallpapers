import { Button, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    width: 1200px;
    height: 700px;

    icon: @image-url("../assets/Alive-Wallpaper-Engine.png");

    title: "Alive wallpaper engine";

    background: #c203fc;


    VerticalBox {

        HorizontalBox {

            // left side sidebar
            Rectangle {
                width: 220px;
                background: #171a22;
            }

            // right side one
            Rectangle {

                background: #111318;

                VerticalBox {

                    // live perview 
                    Rectangle {
                        height: 300px;
                        background: #044bff;
                    }

                    // wallpaper lib
                    Rectangle {
                        background: #0de057;
                    }
                }
            }
        }
    }
}